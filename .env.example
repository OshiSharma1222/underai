# Database — Neon (recommended): Dashboard → Connect → copy connection string
# Use the "pooled" URL for the app. Append sslmode=require if not already present.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Local Postgres (optional alternative):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/underai

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Seeded test user
SEED_USER_EMAIL=broker@underai.io
SEED_USER_PASSWORD=password123

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
# Use gemini-2.5-flash (free tier). Avoid gemini-2.0-flash if you see quota errors.
GEMINI_MODEL=gemini-2.5-flash

# API
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Next.js (public for browser)
NEXT_PUBLIC_API_URL=http://localhost:4000
